# ─────────────────────────────────────────────
# Andamiaje Python — Plantilla de variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas .env al repositorio.
# ─────────────────────────────────────────────

# ── Base de datos ─────────────────────────────
# Docker Compose (usar este cuando se levanta con docker compose up):
DATABASE_URL=postgresql+asyncpg://andamiaje:andamiaje123@db:5432/andamiaje_db
# Local sin Docker (uvicorn directo):
# DATABASE_URL=postgresql+asyncpg://andamiaje:andamiaje123@localhost:5432/andamiaje_db

# ── Seguridad JWT ─────────────────────────────
JWT_SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Claude Haiku (Anthropic) ──────────────────
# Obtén tu key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── SendGrid (email) ──────────────────────────
# Obtén tu key en: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=no-reply@tudominio.com
SENDGRID_FROM_NAME=Andamiaje Python

# ── Frontend (CORS) ───────────────────────────
FRONTEND_URL=http://localhost:8501

# ── Entorno ───────────────────────────────────
ENVIRONMENT=development
# ENVIRONMENT=production

